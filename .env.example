# ─── Polygon.io (market data) ────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# ─── Upstash Redis (scan results, user data, performance records) ─────────────
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── OpenAI (AI narrative generation) ────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Authentication ───────────────────────────────────────────────────────────
# JWT_SECRET: random 256-bit (32 byte) secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_256bit_secret

# ─── Cron / Scanner trigger secret ───────────────────────────────────────────
# Used by /api/scanner/trigger and /api/scanner/merge to authenticate cron jobs
CRON_SECRET=change_me_to_a_random_secret

# ─── Optional: OAuth providers (future) ──────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── App URL (used to build absolute URLs) ───────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
